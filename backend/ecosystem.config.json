{
  "apps": [{
    "name": "cleaning-x-api",
    "script": "server.js",
    "instances": 2,
    "exec_mode": "cluster",
    "max_memory_restart": "800M",
    "node_args": "--max-old-space-size=1024",
    "env": {
      "NODE_ENV": "production",
      "PORT": 8080
    },
    "env_production": {
      "NODE_ENV": "production",
      "PORT": 8080,
      "INSTANCES": 2
    },
    "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
    "error_file": "./logs/err.log",
    "out_file": "./logs/out.log",
    "log_file": "./logs/combined.log",
    "time": true,
    "autorestart": true,
    "max_restarts": 10,
    "min_uptime": "10s",
    "watch": false,
    "ignore_watch": ["node_modules", "logs"],
    "watch_options": {
      "followSymlinks": false
    }
  }]
}
